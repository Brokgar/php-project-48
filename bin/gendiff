#!/usr/bin/env php
<?php

namespace Hexlet\Gendiff;

require_once __DIR__ . '/../vendor/autoload.php';

function main(array $argv): int
{
    array_shift($argv);

    if (in_array('-h', $argv, true) || in_array('--help', $argv, true)) {
        showHelp();
        return 0;
    }

    $options = [];
    $files = [];

    for ($i = 0, $count = count($argv); $i < $count; $i++) {
        $arg = $argv[$i];

        if ($arg === '-f' || $arg === '--format') {
            if ($i + 1 < $count) {
                $options['format'] = $argv[$i + 1];
                $i++;
                continue;
            }

            fwrite(STDERR, "Error: option -f/--format requires a value\n");
            return 1;
        }

        if ($arg === '--color') {
            continue;
        }

        if (str_starts_with($arg, '-')) {
            fwrite(STDERR, "Error: unknown option '{$arg}'\n");
            return 1;
        }

        $files[] = $arg;
    }

    if (count($files) !== 2) {
        fwrite(STDERR, "Error: exactly two files are required\n");
        fwrite(STDERR, "Usage: gendiff [OPTIONS] <file1> <file2>\n");
        return 1;
    }

    try {
        $format = $options['format'] ?? 'stylish';
        $result = Gendiff::compareFiles($files[0], $files[1], $format);
        echo $result;
        return 0;
    } catch (\Throwable $e) {
        fwrite(STDERR, "Error: {$e->getMessage()}\n");
        return 1;
    }
}

function showHelp(): void
{
    $helpText = <<<HELP
Usage: gendiff [OPTIONS] <file1> <file2>

Compares two configuration files and shows a diff.

OPTIONS:
  -h, --help             Show this help
  -f, --format <type>    Output format (plain, stylish, json)

EXAMPLES:
  gendiff file1.json file2.json
  gendiff -f stylish config1.json config2.json --color
  gendiff --help

FORMATS:
  plain   - plain text output with changed properties
  stylish - visual nested output
  json    - JSON representation of diff tree
HELP;

    echo $helpText . "\n";
}

exit(main($argv));
