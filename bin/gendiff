#!/usr/bin/env php
<?php

$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

$autoloadLoaded = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (is_file($autoloadPath)) {
        require_once $autoloadPath;
        $autoloadLoaded = true;
        break;
    }
}

if (!$autoloadLoaded) {
    fwrite(STDERR, 'Error: composer autoload file not found' . PHP_EOL);
    exit(1);
}

function getCliDescription(): string
{
    return <<<DOC
Compares two configuration files and shows a diff.

Usage:
  gendiff [options] [<file1> <file2>]

Options:
  -h --help             Show this help
  -f --format=<type>    Output format [default: stylish]
DOC;
}

function main(array $argv): int
{
    $exitCode = 0;

    $parsed = \Docopt::handle(getCliDescription(), [
        'argv' => array_slice($argv, 1),
        'help' => false,
        'exit' => false,
    ]);

    if (!$parsed->success) {
        fwrite(STDERR, trim($parsed->output) . PHP_EOL);
        $exitCode = 1;
    } elseif ($parsed['--help']) {
        showHelp();
    } elseif ($parsed['<file1>'] === null || $parsed['<file2>'] === null) {
        fwrite(STDERR, 'Error: exactly two files are required' . PHP_EOL);
        fwrite(STDERR, 'Usage: gendiff [OPTIONS] <file1> <file2>' . PHP_EOL);
        $exitCode = 1;
    } else {
        try {
            $format = (string) $parsed['--format'];
            $gendiff = new \Hexlet\Gendiff\Gendiff();
            $result = $gendiff->compareFiles(
                (string) $parsed['<file1>'],
                (string) $parsed['<file2>'],
                $format
            );
            echo $result;
        } catch (\Throwable $e) {
            fwrite(STDERR, "Error: {$e->getMessage()}" . PHP_EOL);
            $exitCode = 1;
        }
    }

    return $exitCode;
}

function showHelp(): void
{
    echo getCliDescription() . PHP_EOL;
}

$exitCode = main($argv);
exit($exitCode);
