{
  "name": "hexlet/code",
  "description": "PHP library for comparing configuration files and generating diffs",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Max Kavun",
      "email": "max.kavun@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Hexlet\\Gendiff\\": "src/"
    },
    "files": [
      "src/functions.php"
    ]
  },
  "bin": [
    "bin/gendiff"
  ],
  "scripts": {
    "test": "@php vendor/bin/phpunit",
    "lint": "@php vendor/bin/phpcs --standard=PSR12 --extensions=php src/ tests/",
    "phpstan": "@php vendor/bin/phpstan analyze --configuration phpstan.neon",
    "analyze": [
      "@lint",
      "@phpstan"
    ]
  },
  "require": {
    "php": "^8.2",
    "symfony/yaml": "^7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "squizlabs/php_codesniffer": "^3.8",
    "phpstan/phpstan": "^1.10"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
